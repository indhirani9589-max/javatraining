import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        int  d;
        Scanner s= new Scanner(System.in);
        d=s.nextInt();
        if(d%4==0 && d%100!=0||d%400==0)
        {
            System.out.println("Leap Year");
            
        }
        else
        {
            System.out.println("Not Leap Year");
        
        }
    }
}
